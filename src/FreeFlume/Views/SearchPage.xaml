<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="FreeFlume.Views.SearchPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FreeFlume.Models"
    xmlns:local="using:FreeFlume.Views"
    mc:Ignorable="d">
    <Page.Resources>
        <DataTemplate x:Key="VideoItemTemplate" x:DataType="models:SearchResult">
            <Grid ColumnSpacing="12" Padding="0,6" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="120" Height="68" CornerRadius="6" Background="Black">
                    <Grid>
                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                        <Grid VerticalAlignment="Bottom" Height="3" Background="#66000000" Visibility="{x:Bind ProgressVisibility}">
                            <Rectangle HorizontalAlignment="Left" Width="{x:Bind ProgressWidth}" Fill="#FFFF0000" />
                        </Grid>
                    </Grid>
                </Border>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{x:Bind Title}" MaxLines="2" TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="{x:Bind Meta, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="ChannelItemTemplate" x:DataType="models:SearchResult">
            <Grid ColumnSpacing="12" Padding="0,6" Background="Transparent">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid Grid.Column="0" Width="120">
                    <Border Width="72" Height="72" CornerRadius="6" Background="#222"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            BorderBrush="#FFFF0000" BorderThickness="{x:Bind LiveRing, Mode=OneWay}">
                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                    </Border>
                </Grid>
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                    <TextBlock Text="{x:Bind Title}" MaxLines="2" TextWrapping="Wrap"
                               TextTrimming="CharacterEllipsis" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                    <TextBlock Text="Channel" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               Style="{ThemeResource CaptionTextBlockStyle}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <local:SearchItemTemplateSelector x:Key="ResultTemplateSelector"
            VideoTemplate="{StaticResource VideoItemTemplate}"
            ChannelTemplate="{StaticResource ChannelItemTemplate}" />
    </Page.Resources>

    <Grid Padding="16,16,8,8" RowSpacing="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Search bar -->
        <Grid Grid.Row="0" ColumnSpacing="8" MaxWidth="720" HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <AutoSuggestBox x:Name="QueryBox" Grid.Column="0" PlaceholderText="Search YT"
                            TextChanged="OnQueryTextChanged" QuerySubmitted="OnQuerySubmitted" GotFocus="OnQueryGotFocus" />
            <Button x:Name="SearchButton" Grid.Column="1" Click="OnSearchClick" Style="{ThemeResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE721;" FontSize="14" />
                    <TextBlock Text="Search" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Filters -->
        <StackPanel x:Name="FilterBar" Grid.Row="1" Orientation="Horizontal" Spacing="8">
            <ComboBox x:Name="SortCombo" MinWidth="140" SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="Relevance" Tag="0" IsSelected="True" />
                <ComboBoxItem Content="Upload date" Tag="2" />
                <ComboBoxItem Content="View count" Tag="3" />
                <ComboBoxItem Content="Rating" Tag="1" />
            </ComboBox>
            <ComboBox x:Name="DateCombo" MinWidth="130" SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="Any date" Tag="0" IsSelected="True" />
                <ComboBoxItem Content="Last hour" Tag="1" />
                <ComboBoxItem Content="Today" Tag="2" />
                <ComboBoxItem Content="This week" Tag="3" />
                <ComboBoxItem Content="This month" Tag="4" />
                <ComboBoxItem Content="This year" Tag="5" />
            </ComboBox>
            <ComboBox x:Name="TypeCombo" MinWidth="120" SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="Any type" Tag="0" IsSelected="True" />
                <ComboBoxItem Content="Video" Tag="1" />
                <ComboBoxItem Content="Channel" Tag="2" />
                <ComboBoxItem Content="Playlist" Tag="3" />
            </ComboBox>
            <ComboBox x:Name="DurationCombo" MinWidth="130" SelectionChanged="OnFilterChanged">
                <ComboBoxItem Content="Any length" Tag="0" IsSelected="True" />
                <ComboBoxItem Content="Under 4 min" Tag="1" />
                <ComboBoxItem Content="4–20 min" Tag="3" />
                <ComboBoxItem Content="Over 20 min" Tag="2" />
            </ComboBox>
            <DropDownButton x:Name="FeaturesButton" Content="Features">
                <DropDownButton.Flyout>
                    <Flyout>
                        <StackPanel Spacing="8" MinWidth="150">
                            <CheckBox x:Name="HdCheck" Content="HD" Checked="OnFeatureChanged" Unchecked="OnFeatureChanged" />
                            <CheckBox x:Name="FourKCheck" Content="4K" Checked="OnFeatureChanged" Unchecked="OnFeatureChanged" />
                            <CheckBox x:Name="SubsCheck" Content="Subtitles / CC" Checked="OnFeatureChanged" Unchecked="OnFeatureChanged" />
                            <CheckBox x:Name="LiveCheck" Content="Live" Checked="OnFeatureChanged" Unchecked="OnFeatureChanged" />
                        </StackPanel>
                    </Flyout>
                </DropDownButton.Flyout>
            </DropDownButton>
        </StackPanel>

        <!-- Drill-in context (channel/playlist) -->
        <StackPanel x:Name="ContextBar" Grid.Row="2" Orientation="Horizontal" Spacing="10"
                    VerticalAlignment="Center" Visibility="Collapsed">
            <Button Click="OnBackToSearch" ToolTipService.ToolTip="Back to results" Padding="10,6">
                <FontIcon Glyph="&#xE72B;" FontSize="14" />
            </Button>
            <TextBlock x:Name="ContextTitle" VerticalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}"
                       TextTrimming="CharacterEllipsis" MaxWidth="360" />
            <!-- Channel tabs: Videos (uploads + live pinned) | Streams (full past+live list). Channel-only. -->
            <StackPanel x:Name="ChannelTabs" Orientation="Horizontal" Spacing="2"
                        VerticalAlignment="Center" Visibility="Collapsed">
                <ToggleButton x:Name="VideosTabBtn" Content="Videos" Click="OnVideosTab" />
                <ToggleButton x:Name="StreamsTabBtn" Content="Streams" Click="OnStreamsTab" />
            </StackPanel>
            <TextBox x:Name="ChannelSearchBox" Width="220" PlaceholderText="Search in channel"
                     VerticalAlignment="Center" Visibility="Collapsed" KeyDown="OnChannelSearchKeyDown" />
        </StackPanel>

        <!-- Results + detail pane -->
        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <ListView x:Name="ResultsView" IsItemClickEnabled="False" SelectionMode="Single"
                          SelectionChanged="OnSelectionChanged" DoubleTapped="OnResultDoubleTapped"
                          ShowsScrollingPlaceholders="True"
                          ItemTemplateSelector="{StaticResource ResultTemplateSelector}" />

                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="40" Height="40"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock x:Name="Status" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" TextAlignment="Center"
                           Text="Search YT to get started." />
            </Grid>

            <!-- Detail pane (shown when a result is selected) -->
            <Border x:Name="DetailPane" Grid.Column="1" Width="320" Visibility="Collapsed"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="14">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                    <StackPanel Spacing="10">
                        <!-- 16:9 thumbnail for videos/playlists -->
                        <Border x:Name="DetailThumbBox" CornerRadius="6" Background="Black">
                            <Image x:Name="DetailThumb" Stretch="UniformToFill" Height="162" />
                        </Border>
                        <!-- square avatar for channels -->
                        <Border x:Name="DetailAvatarBox" CornerRadius="8" Background="#222"
                                Width="148" Height="148" HorizontalAlignment="Center" Visibility="Collapsed">
                            <Image x:Name="DetailAvatar" Stretch="UniformToFill" />
                        </Border>
                        <TextBlock x:Name="DetailTitle" TextWrapping="Wrap"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <HyperlinkButton x:Name="DetailChannel" Click="OnDetailChannelClick" Padding="0"
                                         ToolTipService.ToolTip="Open channel" />
                        <TextBlock x:Name="DetailStats" TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                        <Button x:Name="DetailPlayButton" Click="OnDetailPlay" HorizontalAlignment="Stretch"
                                Style="{ThemeResource AccentButtonStyle}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon x:Name="DetailPlayIcon" Glyph="&#xE768;" FontSize="14" />
                                <TextBlock x:Name="DetailPlayText" Text="Play" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DetailSubscribeButton" Click="OnDetailSubscribe"
                                HorizontalAlignment="Stretch" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE710;" FontSize="14" />
                                <TextBlock x:Name="DetailSubscribeText" Text="Subscribe" />
                            </StackPanel>
                        </Button>
                        <TextBlock x:Name="DetailDesc" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                   Style="{ThemeResource BodyTextBlockStyle}" />
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Pagination -->
        <StackPanel x:Name="Pager" Grid.Row="4" Orientation="Horizontal" Spacing="6"
                    HorizontalAlignment="Center" Visibility="Collapsed">
            <Button x:Name="FirstButton" Click="OnFirstClick" Padding="9,5" ToolTipService.ToolTip="First page">
                <FontIcon Glyph="&#xE892;" FontSize="12" />
            </Button>
            <Button x:Name="PrevButton" Click="OnPrevClick" Padding="9,5" ToolTipService.ToolTip="Previous page">
                <FontIcon Glyph="&#xE76B;" FontSize="12" />
            </Button>
            <TextBlock Text="Page" VerticalAlignment="Center" Margin="6,0,0,0" />
            <NumberBox x:Name="PageBox" Minimum="1" Value="1" Width="78"
                       SpinButtonPlacementMode="Hidden" ValidationMode="InvalidInputOverwritten"
                       VerticalAlignment="Center" ValueChanged="OnPageBoxValueChanged"
                       ToolTipService.ToolTip="Type a page number and press Enter" />
            <TextBlock x:Name="PageTotalText" VerticalAlignment="Center" Margin="0,0,6,0"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" Visibility="Collapsed" />
            <Button x:Name="NextButton" Click="OnNextClick" Padding="9,5" ToolTipService.ToolTip="Next page">
                <FontIcon Glyph="&#xE76C;" FontSize="12" />
            </Button>
            <Button x:Name="LastButton" Click="OnLastClick" Padding="9,5" ToolTipService.ToolTip="Last page" Visibility="Collapsed">
                <FontIcon Glyph="&#xE893;" FontSize="12" />
            </Button>
        </StackPanel>
    </Grid>
</Page>
