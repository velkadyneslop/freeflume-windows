<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="FreeFlume.Views.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:player="using:FreeFlume.Player"
    xmlns:models="using:FreeFlume.Models"
    xmlns:primitives="using:Microsoft.UI.Xaml.Controls.Primitives"
    mc:Ignorable="d"
    IsTabStop="True">
    <Page.Resources>
        <x:String x:Key="GlyphPlay">&#xE768;</x:String>
        <x:String x:Key="GlyphPause">&#xE769;</x:String>
        <x:String x:Key="GlyphVolume">&#xE767;</x:String>
        <x:String x:Key="GlyphMute">&#xE74F;</x:String>
        <x:String x:Key="GlyphFullscreen">&#xE740;</x:String>
        <x:String x:Key="GlyphBackToWindow">&#xE73F;</x:String>
        <Style x:Key="IconBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="AllowFocusOnInteraction" Value="False" />
        </Style>
    </Page.Resources>

    <!-- Everything overlays the video so the title/controls hide without reflowing -->
    <Grid Background="Black" PointerMoved="OnPlayerPointerMoved">
        <Grid x:Name="VideoHost">
            <player:MpvPlayer x:Name="Player" />
        </Grid>

        <!-- Top bar overlay: back + title/channel + info -->
        <Grid x:Name="TopBar" VerticalAlignment="Top" Padding="8" ColumnSpacing="8" Background="#CC101010">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Style="{StaticResource IconBtn}" Click="OnBackClick" ToolTipService.ToolTip="Back">
                <FontIcon Glyph="&#xE72B;" FontSize="16" />
            </Button>
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Foreground="White" Style="{ThemeResource BodyStrongTextBlockStyle}" TextTrimming="CharacterEllipsis" />
                <HyperlinkButton x:Name="ChannelButton" Click="OnChannelClick" Padding="0" Margin="0,-2,0,0"
                                 ToolTipService.ToolTip="Open channel" />
            </StackPanel>
            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button x:Name="QueueButton" Style="{StaticResource IconBtn}" Click="OnQueueClick"
                        Visibility="Collapsed" ToolTipService.ToolTip="Up Next (Q)">
                    <FontIcon Glyph="&#xE71D;" FontSize="16" />
                </Button>
                <Button x:Name="InfoButton" Style="{StaticResource IconBtn}" Click="OnInfoClick" ToolTipService.ToolTip="Video info">
                    <FontIcon Glyph="&#xE946;" FontSize="16" />
                </Button>
            </StackPanel>
        </Grid>

            <!-- Resume prompt (ask mode) -->
            <Border x:Name="ResumeBanner" VerticalAlignment="Top" HorizontalAlignment="Center"
                    Margin="0,16,0,0" Background="#CC101010" CornerRadius="8" Padding="14,10"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="ResumeText" VerticalAlignment="Center" Foreground="White" />
                    <Button Content="Resume" Click="OnResumeClick" Style="{ThemeResource AccentButtonStyle}"
                            AllowFocusOnInteraction="False" />
                    <Button Content="Dismiss" Click="OnDismissResume" Background="Transparent"
                            Foreground="White" BorderThickness="0" AllowFocusOnInteraction="False" />
                </StackPanel>
            </Border>

            <!-- SponsorBlock auto-skip toast -->
            <Border x:Name="SkipToast" VerticalAlignment="Top" HorizontalAlignment="Left"
                    Margin="16,16,0,0" Background="#CC101010" CornerRadius="6" Padding="12,8"
                    Visibility="Collapsed" Tapped="OnToastTapped">
                <TextBlock x:Name="SkipToastText" Foreground="White" Style="{ThemeResource CaptionTextBlockStyle}" />
            </Border>

            <!-- SponsorBlock manual-skip prompt -->
            <Border x:Name="SkipPrompt" VerticalAlignment="Top" HorizontalAlignment="Center"
                    Margin="0,16,0,0" Background="#CC101010" CornerRadius="6" Padding="14,10"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock x:Name="SkipPromptText" Foreground="White" VerticalAlignment="Center" />
                    <Button Content="Skip" Click="OnManualSkipClick" Style="{ThemeResource AccentButtonStyle}"
                            AllowFocusOnInteraction="False" />
                </StackPanel>
            </Border>

            <!-- Info panel: slides in from the right (non-modal; video keeps playing) -->
            <Border x:Name="InfoPanel" HorizontalAlignment="Right" Width="380" Visibility="Collapsed"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="InfoPanelTransform" />
                </Border.RenderTransform>
                <Grid Padding="16,16,16,64">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" ColumnSpacing="8" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="InfoTitle" TextWrapping="Wrap" VerticalAlignment="Center"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Button Grid.Column="1" VerticalAlignment="Top" Click="OnInfoClose"
                                Background="Transparent" BorderThickness="0" Padding="6"
                                ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </Grid>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollMode="Disabled">
                        <StackPanel Spacing="10">
                            <HyperlinkButton x:Name="InfoChannel" Click="OnInfoChannelClick" Padding="0"
                                             Visibility="Collapsed" ToolTipService.ToolTip="Open channel" />
                            <TextBlock x:Name="InfoStats" TextWrapping="Wrap"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       Style="{ThemeResource CaptionTextBlockStyle}" />
                            <TextBlock x:Name="InfoDesc" TextWrapping="Wrap" IsTextSelectionEnabled="True"
                                       Style="{ThemeResource BodyTextBlockStyle}" />
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- "Up Next" queue panel: slides in from the right (like the info panel) -->
            <Border x:Name="QueuePanel" HorizontalAlignment="Right" Width="360" Visibility="Collapsed"
                    Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1,0,0,0">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="QueuePanelTransform" />
                </Border.RenderTransform>
                <Grid Padding="16,16,8,76">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,8,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Up Next" VerticalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <Button Grid.Column="1" Click="OnQueueClose" Background="Transparent" BorderThickness="0"
                                Padding="6" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </Grid>
                    <CheckBox x:Name="QueueAutoplayCheck" Grid.Row="1" Content="Autoplay next" Margin="0,0,0,6"
                              Checked="OnQueueAutoplayToggled" Unchecked="OnQueueAutoplayToggled" />
                    <ListView x:Name="QueueList" Grid.Row="2" SelectionMode="None" IsItemClickEnabled="True"
                              ItemClick="OnQueueItemClick" CanReorderItems="True" AllowDrop="True" CanDragItems="True">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:SearchResult">
                                <Grid ColumnSpacing="10" Padding="4" CornerRadius="6"
                                      Background="{x:Bind QueueHighlight, Mode=OneWay}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Width="84" Height="47" CornerRadius="4" Background="Black">
                                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Title}" MaxLines="2" TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind Meta, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <Border x:Name="TransportBar" Canvas.ZIndex="5" VerticalAlignment="Bottom" Background="#CC101010" Padding="12,4,12,6">
                <StackPanel Spacing="2">
                    <!-- Row 1: just the seekbar -->
                    <Grid x:Name="SeekArea" VerticalAlignment="Center" SizeChanged="OnSeekAreaSizeChanged">
                        <Slider x:Name="SeekSlider" VerticalAlignment="Center"
                                Minimum="0" Maximum="100" StepFrequency="1"
                                ValueChanged="OnSeekValueChanged" ThumbToolTipValueConverter="{x:Null}" />
                        <Canvas x:Name="SegmentCanvas" IsHitTestVisible="False" />
                        <Canvas x:Name="ChapterCanvas" IsHitTestVisible="False" />

                        <!-- Storyboard hover preview: a Popup so it never affects seekbar layout -->
                        <primitives:Popup x:Name="PreviewPopup" IsHitTestVisible="False">
                            <Border Background="#EE0A0A0A" BorderBrush="#66FFFFFF" BorderThickness="1"
                                    CornerRadius="6" Padding="3">
                                <StackPanel Spacing="2">
                                    <Canvas x:Name="PreviewClip">
                                        <Image x:Name="PreviewSprite" Stretch="Fill" />
                                    </Canvas>
                                    <TextBlock x:Name="PreviewChapter" Foreground="#FFE0E0E0" HorizontalAlignment="Center"
                                               TextAlignment="Center" MaxWidth="220" TextWrapping="NoWrap"
                                               TextTrimming="CharacterEllipsis" Visibility="Collapsed"
                                               Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock x:Name="PreviewTime" Foreground="White" HorizontalAlignment="Center"
                                               Style="{ThemeResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </Border>
                        </primitives:Popup>
                    </Grid>

                    <!-- Row 2: controls -->
                    <Grid ColumnSpacing="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />  <!-- 0 previous -->
                            <ColumnDefinition Width="Auto" />  <!-- 1 play -->
                            <ColumnDefinition Width="Auto" />  <!-- 2 next -->
                            <ColumnDefinition Width="Auto" />  <!-- 3 mute -->
                            <ColumnDefinition Width="Auto" />  <!-- 4 volume -->
                            <ColumnDefinition Width="Auto" />  <!-- 5 time -->
                            <ColumnDefinition Width="*" />     <!-- 6 spacer -->
                            <ColumnDefinition Width="Auto" />  <!-- 7 loop -->
                            <ColumnDefinition Width="Auto" />  <!-- 8 screenshot -->
                            <ColumnDefinition Width="Auto" />  <!-- 9 captions -->
                            <ColumnDefinition Width="Auto" />  <!-- 10 speed -->
                            <ColumnDefinition Width="Auto" />  <!-- 11 quality -->
                            <ColumnDefinition Width="Auto" />  <!-- 12 chapters -->
                            <ColumnDefinition Width="Auto" />  <!-- 13 picture-in-picture -->
                            <ColumnDefinition Width="Auto" />  <!-- 14 fullscreen -->
                        </Grid.ColumnDefinitions>

                        <Button x:Name="PrevButton" Grid.Column="0" Style="{StaticResource IconBtn}"
                                Visibility="Collapsed" Click="OnPrevClick" ToolTipService.ToolTip="Previous (P)">
                            <FontIcon Glyph="&#xE892;" FontSize="16" />
                        </Button>

                        <Button x:Name="PlayPauseButton" Grid.Column="1" Style="{StaticResource IconBtn}"
                                Click="OnPlayPauseClick" ToolTipService.ToolTip="Play/Pause">
                            <FontIcon x:Name="PlayPauseIcon" Glyph="&#xE769;" FontSize="16" />
                        </Button>

                        <Button x:Name="NextButton" Grid.Column="2" Style="{StaticResource IconBtn}"
                                Visibility="Collapsed" Click="OnNextClick" ToolTipService.ToolTip="Next (N)">
                            <FontIcon Glyph="&#xE893;" FontSize="16" />
                        </Button>

                        <Button x:Name="MuteButton" Grid.Column="3" Style="{StaticResource IconBtn}"
                                Click="OnMuteClick" ToolTipService.ToolTip="Mute">
                            <FontIcon x:Name="MuteIcon" Glyph="&#xE767;" FontSize="16" />
                        </Button>

                        <Slider x:Name="VolumeSlider" Grid.Column="4" Width="86" VerticalAlignment="Center"
                                Minimum="0" Maximum="130" Value="100" AllowFocusOnInteraction="False"
                                ValueChanged="OnVolumeValueChanged" />

                        <TextBlock x:Name="TimeText" Grid.Column="5" Foreground="White" VerticalAlignment="Center"
                                   Text="0:00 / 0:00" Margin="8,0" Style="{ThemeResource CaptionTextBlockStyle}" />

                        <Button x:Name="LoopButton" Grid.Column="7" Style="{StaticResource IconBtn}"
                                Click="OnLoopClick" ToolTipService.ToolTip="Loop (R)">
                            <FontIcon x:Name="LoopIcon" Glyph="&#xE8EE;" FontSize="16" />
                        </Button>

                        <Button x:Name="ScreenshotButton" Grid.Column="8" Style="{StaticResource IconBtn}"
                                Click="OnScreenshotClick" ToolTipService.ToolTip="Screenshot (S)">
                            <FontIcon Glyph="&#xE722;" FontSize="16" />
                        </Button>

                        <SplitButton x:Name="CcButton" Grid.Column="9" Click="OnCcToggle" ToolTipService.ToolTip="Captions"
                                     Background="Transparent" BorderThickness="0" Foreground="White"
                                     Padding="8,6" AllowFocusOnInteraction="False">
                            <FontIcon x:Name="CcIcon" Glyph="&#xED1E;" FontSize="16" />
                        </SplitButton>

                        <DropDownButton x:Name="SpeedButton" Grid.Column="10" Content="1×" ToolTipService.ToolTip="Speed"
                                        Background="Transparent" BorderThickness="0" Foreground="White"
                                        Padding="8,6" AllowFocusOnInteraction="False" />

                        <DropDownButton x:Name="QualityButton" Grid.Column="11" Content="Auto" ToolTipService.ToolTip="Quality"
                                        Background="Transparent" BorderThickness="0" Foreground="White"
                                        Padding="8,6" AllowFocusOnInteraction="False" />

                        <Button x:Name="ChaptersButton" Grid.Column="12" Style="{StaticResource IconBtn}"
                                Visibility="Collapsed" ToolTipService.ToolTip="Chapters">
                            <FontIcon Glyph="&#xE8FD;" FontSize="16" />
                        </Button>

                        <Button x:Name="PipButton" Grid.Column="13" Style="{StaticResource IconBtn}"
                                Click="OnPipClick" ToolTipService.ToolTip="Picture-in-picture">
                            <FontIcon Glyph="&#xE8A7;" FontSize="16" />
                        </Button>

                        <Button x:Name="FullscreenButton" Grid.Column="14" Style="{StaticResource IconBtn}"
                                Click="OnFullscreenClick" ToolTipService.ToolTip="Fullscreen">
                            <FontIcon x:Name="FullscreenIcon" Glyph="&#xE740;" FontSize="16" />
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Placard shown over the video while it's playing in the separate PiP window -->
            <Grid x:Name="PipBanner" Visibility="Collapsed" Background="#E6000000">
                <StackPanel Spacing="16" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <FontIcon Glyph="&#xE8A7;" FontSize="40" Foreground="White" HorizontalAlignment="Center" />
                    <TextBlock Text="This video is playing in Picture-in-Picture" Foreground="White"
                               HorizontalAlignment="Center" Style="{ThemeResource SubtitleTextBlockStyle}" />
                    <Button Content="Return to player" Click="OnReturnFromPip"
                            Style="{ThemeResource AccentButtonStyle}" HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
    </Grid>
</Page>
