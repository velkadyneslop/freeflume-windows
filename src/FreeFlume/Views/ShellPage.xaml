<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="FreeFlume.Views.ShellPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <!-- Native Windows iconography: FontIcon defaults to SymbolThemeFontFamily
         (Segoe Fluent Icons on Win11, Segoe MDL2 Assets fallback on Win10). -->
    <NavigationView
        x:Name="Nav"
        PaneDisplayMode="Left"
        PaneTitle="FreeFlume"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="True"
        IsTitleBarAutoPaddingEnabled="False"
        Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
        SelectionChanged="OnSelectionChanged">

        <!-- Solid, theme-aware pane background (no Mica on Win10, so the default acrylic
             samples the dark window and looks wrong in Light theme). -->
        <NavigationView.Resources>
            <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{ThemeResource SolidBackgroundFillColorBase}" />
            <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{ThemeResource SolidBackgroundFillColorBase}" />
            <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="{ThemeResource SolidBackgroundFillColorBase}" />
        </NavigationView.Resources>

        <NavigationView.MenuItems>
            <NavigationViewItem Content="Search" Tag="SearchPage" IsSelected="True">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE721;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Subscriptions" Tag="SubscriptionsPage">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8F1;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="History" Tag="HistoryPage">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE81C;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Playlists" Tag="PlaylistsPage">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8FD;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem Content="Downloads" Tag="DownloadsPage">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE896;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid>
            <Frame x:Name="ContentFrame" />

            <!-- Mini player: the live video reparented here while browsing -->
            <Border x:Name="MiniPanel" Visibility="Collapsed" Width="400"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,16,16"
                    Background="Black" CornerRadius="8"
                    BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="1">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="225" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid x:Name="MiniVideoHost" Grid.Row="0" Background="Black" Tapped="OnMiniTapped" />
                    <Grid Grid.Row="1" Background="#FF101010" Padding="6,4" ColumnSpacing="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Click="OnMiniPlayPause" Background="Transparent" BorderThickness="0"
                                Foreground="White" Padding="6" ToolTipService.ToolTip="Play/Pause">
                            <FontIcon x:Name="MiniPlayIcon" Glyph="&#xE769;" FontSize="14" />
                        </Button>
                        <TextBlock x:Name="MiniTitle" Grid.Column="1" Foreground="White" VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis" Style="{ThemeResource CaptionTextBlockStyle}" />
                        <Button Grid.Column="2" Click="OnMiniExpand" Background="Transparent" BorderThickness="0"
                                Foreground="White" Padding="6" ToolTipService.ToolTip="Expand">
                            <FontIcon Glyph="&#xE740;" FontSize="14" />
                        </Button>
                        <Button Grid.Column="3" Click="OnMiniClose" Background="Transparent" BorderThickness="0"
                                Foreground="White" Padding="6" ToolTipService.ToolTip="Close">
                            <FontIcon Glyph="&#xE711;" FontSize="14" />
                        </Button>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </NavigationView>
</Page>
