<?xml version="1.0" encoding="UTF-8" ?>
<ContentDialog
    x:Class="FreeFlume.Views.AddToPlaylistDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Add to playlist"
    PrimaryButtonText="Add"
    CloseButtonText="Cancel"
    DefaultButton="Primary">
    <StackPanel Spacing="12" MinWidth="320">
        <ComboBox x:Name="PlaylistCombo" Header="Existing playlist"
                  HorizontalAlignment="Stretch" DisplayMemberPath="Name" />
        <TextBox x:Name="NewNameBox" Header="…or create a new playlist"
                 PlaceholderText="New playlist name" />
    </StackPanel>
</ContentDialog>
