<?xml version="1.0" encoding="UTF-8" ?>
<Page
    x:Class="FreeFlume.Views.SubscriptionsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:FreeFlume.Models"
    mc:Ignorable="d">
    <Grid Padding="16,16,8,8" ColumnSpacing="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left: channels -->
        <Grid Grid.Column="0" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Subscriptions" Style="{ThemeResource TitleTextBlockStyle}" />
            <Button x:Name="WhatsNewButton" Grid.Row="1" HorizontalAlignment="Stretch" Click="OnWhatsNewClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE789;" FontSize="14" />
                    <TextBlock Text="What's New" />
                </StackPanel>
            </Button>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
                <Button x:Name="ImportButton" Content="Import" Click="OnImportClick" ToolTipService.ToolTip="Import from NewPipe, FreeTube, Takeout, OPML, or a URL list" />
                <Button x:Name="ExportButton" Content="Export" Click="OnExportClick" ToolTipService.ToolTip="Export as OPML" />
            </StackPanel>
            <ListView x:Name="ChannelsView" Grid.Row="3" SelectionMode="Single" SelectionChanged="OnChannelSelected">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:Subscription">
                        <Grid ColumnSpacing="10" Padding="0,6" Background="Transparent">
                            <Grid.ContextFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="Open Channel" Click="OnChannelOpen" />
                                    <MenuFlyoutItem Text="Copy Link" Click="OnChannelCopyLink" />
                                    <MenuFlyoutItem Text="Open in Browser" Click="OnChannelOpenBrowser" />
                                    <MenuFlyoutSeparator />
                                    <MenuFlyoutItem Text="Unsubscribe" Click="OnUnsubscribe" />
                                </MenuFlyout>
                            </Grid.ContextFlyout>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Width="32" Height="32" CornerRadius="16" Background="#333"
                                    BorderBrush="#FFFF0000" BorderThickness="{x:Bind LiveRing, Mode=OneWay}">
                                <Image Source="{x:Bind Avatar}" Stretch="UniformToFill" />
                            </Border>
                            <TextBlock Grid.Column="1" Text="{x:Bind ChannelName}" VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>

        <!-- Right: feed -->
        <Grid Grid.Column="1" RowSpacing="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock x:Name="FeedTitle" Grid.Row="0" Text="What's New" Style="{ThemeResource SubtitleTextBlockStyle}" />
            <Grid Grid.Row="1">
                <ListView x:Name="FeedView" IsItemClickEnabled="True" SelectionMode="None" ItemClick="OnFeedItemClick">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:SearchResult">
                            <Grid ColumnSpacing="12" Padding="0,6" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Width="120" Height="68" CornerRadius="6" Background="Black">
                                    <Grid>
                                        <Image Source="{x:Bind Thumbnail}" Stretch="UniformToFill" />
                                        <Grid VerticalAlignment="Bottom" Height="3" Background="#66000000" Visibility="{x:Bind ProgressVisibility}">
                                            <Rectangle HorizontalAlignment="Left" Width="{x:Bind ProgressWidth}" Fill="#FFFF0000" />
                                        </Grid>
                                    </Grid>
                                </Border>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                    <TextBlock Text="{x:Bind Title}" MaxLines="2" TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis" Style="{ThemeResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind Meta, Mode=OneWay}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               Style="{ThemeResource CaptionTextBlockStyle}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                <ProgressRing x:Name="LoadingRing" IsActive="False" Width="40" Height="40"
                              HorizontalAlignment="Center" VerticalAlignment="Center" />
                <TextBlock x:Name="Status" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Style="{ThemeResource BodyTextBlockStyle}" TextWrapping="Wrap" TextAlignment="Center"
                           Text="Subscribe to channels from Search to see their latest uploads here." />
            </Grid>
        </Grid>
    </Grid>
</Page>
